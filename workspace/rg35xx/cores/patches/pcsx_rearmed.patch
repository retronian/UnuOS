diff --git a/Makefile.libretro b/Makefile.libretro
--- a/Makefile.libretro
+++ b/Makefile.libretro
@@ -596,2 +596,20 @@ else ifeq ($(platform), miyoo)
 
+# RG35XX
+else ifeq ($(platform), rg35xx)
+	TARGET := $(TARGET_NAME)_libretro.so
+	CC = $(CROSS_COMPILE)gcc
+	CXX = $(CROSS_COMPILE)g++
+	AR = $(CROSS_COMPILE)ar
+	CFLAGS += -marm -mtune=cortex-a9 -mfpu=neon-fp16 -mfloat-abi=hard -march=armv7-a -fomit-frame-pointer
+	ASFLAGS += -marm -mtune=cortex-a9 -mfpu=neon-fp16 -mfloat-abi=hard -march=armv7-a
+	CFLAGS += -ffast-math -fdata-sections -ffunction-sections -fsingle-precision-constant -flto -fPIC -DNO_HWCAP
+	LDFLAGS += -flto -fPIC
+	CPU_ARCH := arm
+	OPTIMIZE += -Ofast -DNDEBUG=1
+	HAVE_NEON = 1
+	HAVE_NEON_ASM = 1
+	BUILTIN_GPU = neon
+	ARCH = arm
+	DYNAREC = ari64
+
 # Emscripten
